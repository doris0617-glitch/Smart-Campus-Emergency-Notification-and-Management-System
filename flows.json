eturn this.data.statusColor || '#333333'\n        },\n\n        bgColor() {\n            return this.data.bgColor || '#eeeeee'\n        },\n\n        borderColor() {\n            return this.data.borderColor || '#999999'\n        },\n\n        cardStyle() {\n            return {\n                backgroundColor: this.bgColor,\n                borderColor: this.borderColor\n            }\n        },\n\n        locationName() {\n            return this.data.location_name || '尚無資料'\n        },\n\n        deviceId() {\n            return this.data.device_id || '尚無資料'\n        },\n\n        message() {\n            return this.data.message || '目前沒有事件'\n        },\n\n        eventId() {\n            return this.data.event_id || '尚無事件編號'\n        },\n\n        displayTime() {\n            return this.data.timeOnly || '尚無時間'\n        }\n    }\n}\n</script>\n\n<style>\n.emergency-card {\n    font-family: \"Microsoft JhengHei\", Arial, sans-serif;\n    padding: 24px;\n    border-radius: 20px;\n    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);\n    border: 3px solid #cccccc;\n    margin: 12px;\n}\n\n.header {\n    text-align: center;\n    margin-bottom: 20px;\n}\n\n.icon {\n    font-size: 50px;\n}\n\n.status-text {\n    font-size: 36px;\n    font-weight: bold;\n    margin-top: 8px;\n}\n\n.info-box {\n    background: white;\n    border-radius: 14px;\n    padding: 18px 24px;\n    font-size: 20px;\n}\n\n.row {\n    display: flex;\n    justify-content: space-between;\n    margin: 12px 0;\n}\n\n.label {\n    color: #555555;\n}\n\n.value {\n    font-weight: bold;\n    color: #111111;\n}\n\n.message {\n    margin-top: 15px;\n}\n\n.message-text {\n    margin-top: 8px;\n    font-size: 22px;\n    font-weight: bold;\n    color: #111111;\n}\n\n.event-id {\n    margin-top: 15px;\n    text-align: center;\n    font-size: 13px;\n    color: #666666;\n}\n</style>",
