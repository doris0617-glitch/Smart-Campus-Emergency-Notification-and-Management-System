    {
        "id": "59adc3476534c714",
        "type": "function",
        "z": "44b97e77d42e5fa9",
        "name": "整理dashboard資料",
        "func": "let data = msg.payload;\n\n// 如果 mqtt in 後面沒有接 json，這裡可以保險轉換\nif (typeof data === \"string\") {\n    try {\n        data = JSON.parse(data);\n    } catch (e) {\n        node.warn(\"收到的資料不是合法 JSON：\" + data);\n        return null;\n    }\n}\n\n// 檢查必要欄位\nif (!data.location_id || !data.status) {\n    node.warn(\"缺少 location_id 或 status\");\n    return null;\n}\n\n// 儲存每個地點最後狀態\nflow.set(data.location_id + \"_status\", data.status);\nflow.set(data.location_id + \"_device\", data.device_id);\nflow.set(data.location_id + \"_name\", data.location_name);\nflow.set(data.location_id + \"_message\", data.message);\n\n// 只有 triggered 或 normal 才更新「發生時間」\n// resolved 不要覆蓋發生時間\nif (data.status === \"triggered\" || data.status === \"normal\") {\n    flow.set(data.location_id + \"_time\", data.timestamp);\n}\n\n// 從 flow 取出原本的發生時間\nlet eventTime = flow.get(data.location_id + \"_time\") || data.timestamp || \"無資料\";\n\n// 處理完成時間\nlet resolvedTime = \"尚未處理\";\n\nif (data.status === \"resolved\") {\n    resolvedTime = data.resolved_time || data.timestamp || \"尚未處理\";\n}\n\n// 發生時間只取 HH:MM:SS\nlet eventTimeOnly = \"無資料\";\n\nif (eventTime && eventTime.length >= 19) {\n    eventTimeOnly = eventTime.substring(11, 19);\n}\n\n// 狀態設定\nlet statusText = \"\";\nlet statusIcon = \"\";\nlet statusColor = \"\";\nlet bgColor = \"\";\nlet borderColor = \"\";\n\nif (data.status === \"triggered\") {\n    statusText = \"警報中\";\n    statusIcon = \"🚨\";\n    statusColor = \"#c62828\";\n    bgColor = \"#ffebee\";\n    borderColor = \"#ef5350\";\n} else if (data.status === \"resolved\") {\n    statusText = \"已處理\";\n    statusIcon = \"✅\";\n    statusColor = \"#2e7d32\";\n    bgColor = \"#e8f5e9\";\n    borderColor = \"#66bb6a\";\n} else if (data.status === \"normal\") {\n    statusText = \"未發生事件\";\n    statusIcon = \"⚪\";\n    statusColor = \"#333333\";\n    bgColor = \"#eeeeee\";\n    borderColor = \"#999999\";\n} else {\n    statusText = \"未知狀態\";\n    statusIcon = \"⚠️\";\n    statusColor = \"#555555\";\n    bgColor = \"#eeeeee\";\n    borderColor = \"#999999\";\n}\n\n// 整理給 dashboard 用的資料\nmsg.payload = {\n    event_id: data.event_id || \"無資料\",\n    location_id: data.location_id,\n    location_name: data.location_name || \"無資料\",\n    device_id: data.device_id || \"無資料\",\n    status: data.status || \"無資料\",\n    statusText: statusText,\n    statusIcon: statusIcon,\n    statusColor: statusColor,\n    bgColor: bgColor,\n    borderColor: borderColor,\n    message: data.message || \"目前沒有事件\",\n\n    // 這個是原本事件發生時間\n    timestamp: eventTime,\n\n    // 這個是處理完成時間\n    resolved_time: resolvedTime,\n    resolvedTime: resolvedTime,\n\n    // 這個給 dashboard 顯示 HH:MM:SS\n    timeOnly: eventTimeOnly\n};\n\n// 分流給不同 dashboard\nif (data.location_id === \"lab\") {\n    return [msg, null];\n}\n\nif (data.location_id === \"dorm\") {\n    return [null, msg];\n}\n\nnode.warn(\"未知的 location_id：\" + data.location_id);\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
