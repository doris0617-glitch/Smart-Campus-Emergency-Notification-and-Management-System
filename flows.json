    {
        "id": "0eb8de5a52bd6388",
        "type": "ui-template",
        "z": "44b97e77d42e5fa9",
        "group": "444ddd09bbfbfd7e",
        "page": "",
        "ui": "",
        "name": "事件狀態卡片",
        "order": 0,
        "width": "6",
        "height": "11",
        "head": "",
        "format": "<template>\n    <div class=\"emergency-card\" :style=\"cardStyle\">\n\n        <div class=\"header\">\n            <div class=\"icon\">{{ statusIcon }}</div>\n            <div class=\"status-text\" :style=\"{ color: statusColor }\">\n                {{ statusText }}\n            </div>\n        </div>\n\n        <div class=\"info-box\">\n            <div class=\"row\">\n                <span class=\"label\">📍 事件地點</span>\n                <span class=\"value\">{{ locationName }}</span>\n            </div>\n\n            <div class=\"row\">\n                <span class=\"label\">⏰ 發生時間</span>\n                <span class=\"value\">{{ displayTime }}</span>\n            </div>\n\n            <div class=\"row\">\n                <span class=\"label\">✅ 處理完成時間</span>\n                <span class=\"value\">{{msg.payload.resolved_time}}</span>\n            </div>\n            \n            <div class=\"row\">\n                <span class=\"label\">💻 設備名稱</span>\n                <span class=\"value\">{{ deviceId }}</span>\n            </div>\n\n            <div class=\"row\">\n                <span class=\"label\">📌 事件狀態</span>\n                <span class=\"value\">{{ rawStatus }}</span>\n            </div>\n\n            <hr>\n\n            <div class=\"message\">\n                <div class=\"label\">💬 事件訊息</div>\n                <div class=\"message-text\">{{ message }}</div>\n            </div>\n        </div>\n\n        <div class=\"event-id\">\n            Event ID：{{ eventId }}\n        </div>\n\n    </div>\n</template>\n\n<script>\nexport default {\n    computed: {\n        data() {\n            return this.msg?.payload || {}\n        },\n\n        rawStatus() {\n            return this.data.status || 'normal'\n        },\n\n        statusText() {\n            return this.data.statusText || '未發生事件'\n        },\n\n        statusIcon() {\n            return this.data.statusIcon || '⚪'\n        },\n\n        statusColor() {\n            return this.data.statusColor || '#333333'\n        },\n\n        bgColor() {\n            return this.data.bgColor || '#eeeeee'\n        },\n\n        borderColor() {\n            return this.data.borderColor || '#999999'\n        },\n\n        cardStyle() {\n            return {\n                backgroundColor: this.bgColor,\n                borderColor: this.borderColor\n            }\n        },\n\n        locationName() {\n            return this.data.location_name || '尚無資料'\n        },\n\n        deviceId() {\n            return this.data.device_id || '尚無資料'\n        },\n\n        message() {\n            return this.data.message || '目前沒有事件'\n        },\n\n        eventId() {\n            return this.data.event_id || '尚無事件編號'\n        },\n\n        displayTime() {\n            return this.data.timeOnly || '尚無時間'\n        }\n    }\n}\n</script>\n\n<style>\n.emergency-card {\n    font-family: \"Microsoft JhengHei\", Arial, sans-serif;\n    padding: 24px;\n    border-radius: 20px;\n    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);\n    border: 3px solid #cccccc;\n    margin: 12px;\n}\n\n.header {\n    text-align: center;\n    margin-bottom: 20px;\n}\n\n.icon {\n    font-size: 50px;\n}\n\n.status-text {\n    font-size: 36px;\n    font-weight: bold;\n    margin-top: 8px;\n}\n\n.info-box {\n    background: white;\n    border-radius: 14px;\n    padding: 18px 24px;\n    font-size: 20px;\n}\n\n.row {\n    display: flex;\n    justify-content: space-between;\n    margin: 12px 0;\n}\n\n.label {\n    color: #555555;\n}\n\n.value {\n    font-weight: bold;\n    color: #111111;\n}\n\n.message {\n    margin-top: 15px;\n}\n\n.message-text {\n    margin-top: 8px;\n    font-size: 22px;\n    font-weight: bold;\n    color: #111111;\n}\n\n.event-id {\n    margin-top: 15px;\n    text-align: center;\n    font-size: 13px;\n    color: #666666;\n}\n</style>",
